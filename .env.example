# // ENTERPRISE FIX: Final One-Click Production Launch v3 - 2026-02-27
# Security template for production launch.
# IMPORTANT: Never commit real secrets in .env. Keep .env local/private.

# Runtime
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=file:./prisma/dev.db

# Auth & Security
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=24h
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN
BACKUP_API_TOKEN=CHANGE_ME_BACKUP_TOKEN
BACKUP_ENCRYPTION_SECRET=CHANGE_ME_BACKUP_SECRET
BACKUP_RESTORE_PIN=CHANGE_ME_PIN

# Network Security
CORS_ORIGINS=https://your-domain.com
RATE_LIMIT_PER_MINUTE=100

# Frontend runtime vars
VITE_API_URL=/api
VITE_REALTIME_URL=
VITE_BACKUP_API_TOKEN=

# Launch behavior
PROXY_PROVIDER=nginx
FORCE_PM2=0
PM2_INSTANCES=max

# Health checks
HEALTH_URL=http://localhost/api/health
HEALTH_TIMEOUT_MS=8000
