DATABASE_URL=postgresql://feedfactory:SecurePassword2026!@localhost:5432/feed_factory_db
DATABASE_DIRECT_URL=postgresql://feedfactory:SecurePassword2026!@localhost:5432/feed_factory_db
JWT_SECRET=phase-0-production-secret-2026
PORT=3001

# ============================================
# SECURITY SETTINGS - REQUIRED FOR PRODUCTION
# ============================================

# System Reset Token - Minimum 16 characters
# Used for confirming system reset operations
SYSTEM_RESET_TOKEN=CHANGE_THIS_TO_SECURE_RANDOM_TOKEN_MIN_32_CHARS

# Backup Encryption Secret - Minimum 32 characters
# Used for encrypting backup files
BACKUP_ENCRYPTION_SECRET=CHANGE_THIS_TO_SECURE_SECRET_MIN_32_CHARS

# CORS Settings - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Allow GitHub Codespaces origins (true/false)
# Set to true only if using GitHub Codespaces
ALLOW_CODESPACES_ORIGINS=false

# Environment (development/production)
NODE_ENV=development
